{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "builder": "@vercel/python",
      "entrypoint": "app/main.py",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/_/backend/api/:path*" },
    { "source": "/health", "destination": "/_/backend/health" }
  ]
}